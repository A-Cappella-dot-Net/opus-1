<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <import resource="madrigalConfig.xml"/>
    <import resource="prestoClient.xml"/>

    <bean name="incrementalIdGenerator" class="net.a_cappella.madrigal.common.utils.IncrementalIdGenerator">
        <constructor-arg index="0" value="../" />
        <constructor-arg index="1" value="${idGen.prefix}" />
        <constructor-arg index="2" value="yyMMdd" />
        <constructor-arg index="3" value="1000" />
    </bean>

	<bean name="ioc" class="net.a_cappella.test.madrigal.ox.IocExerciser">
		<constructor-arg index="0" value="${ordex.use.native}" />
		<constructor-arg index="1" value="${ordex.size.sequence}" />
	</bean>

	<bean name="rwt" class="net.a_cappella.test.madrigal.ox.RwtExerciser">
		<constructor-arg index="0" value="${ordex.use.native}" />
		<constructor-arg index="1" value="${ordex.size.sequence}" />
	</bean>

	<bean name="ibg" class="net.a_cappella.test.madrigal.ox.IbgExerciser">
		<constructor-arg index="0" value="${ordex.use.native}" />
		<constructor-arg index="1" value="${ordex.size.sequence}" />
	</bean>

	<bean name="sth" class="net.a_cappella.test.madrigal.ox.SthExerciser">
		<constructor-arg index="0" value="${ordex.use.native}" />
		<constructor-arg index="1" value="${ordex.size.sequence}" />
	</bean>

    <bean name="orderExerciser" class="net.a_cappella.test.madrigal.ox.OrderExerciser" init-method="init" >
        <constructor-arg index="0" value="${ordex.ecn}" />
        <constructor-arg index="1" value="exerciser" />
        <constructor-arg index="2" value="exerciser" />
        <constructor-arg index="3" ref="client" />
        <constructor-arg index="4" ref="incrementalIdGenerator" />
        <constructor-arg index="5" value="${ordex.when.empty.stack.use.last.cached}" />
        <constructor-arg index="6" ref="${ordex.feature.exerciser}" />
    </bean>

    <!-- import resource="jmx.xml"/ -->
</beans>
