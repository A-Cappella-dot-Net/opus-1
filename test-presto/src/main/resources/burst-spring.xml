<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

	<!-- import resource="prestoConfig.xml"/ -->
	<import resource="madrigalConfig.xml"/>
	<import resource="prestoClient.xml"/>

	<bean name="burstPing" class="net.a_cappella.test.madrigal.perf.MadBurst" init-method="start">
		<constructor-arg index="0" ref="client" />

		<property name="pinToCpu" value="${pin.to.cpu}"/>
	</bean>
</beans>
