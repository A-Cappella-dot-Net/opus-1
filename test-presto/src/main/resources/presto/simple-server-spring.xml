<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <import resource="../prestoConfig.xml"/>

    <bean name="msgCoder" class="net.a_cappella.continuo.msg.MsgCoder" />

    <bean name="server" class="net.a_cappella.test.presto.SimpleServer" init-method="startSink" >
        <constructor-arg index="0" ref="msgCoder" />
        <constructor-arg index="1" value="${my.info}" />
    </bean>

    <!-- import resource="jmx.xml"/ -->
</beans>