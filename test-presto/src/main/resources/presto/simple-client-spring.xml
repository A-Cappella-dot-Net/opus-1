<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <import resource="../prestoConfig.xml"/>

    <bean name="msgCoder" class="net.a_cappella.continuo.msg.MsgCoder" />

    <bean name="client" class="net.a_cappella.test.presto.SimpleClient" init-method="start">
        <constructor-arg index="0" ref="msgCoder" />
        <constructor-arg index="1" value="${my.info}" />
        <constructor-arg index="2" value="${server.info}" />
        <constructor-arg index="3" value="" />
    </bean>
</beans>