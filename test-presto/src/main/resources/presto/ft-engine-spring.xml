<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <import resource="../prestoConfig.xml"/>

    <bean name="msgCoder" class="net.a_cappella.continuo.msg.MsgCoder" />

    <bean name="versionedParamsCache" class="net.a_cappella.presto.ft.upgrade.VersionedParamsCache" init-method="start">
        <constructor-arg index="0" value="${upgraded.params.file}" />
    </bean>

    <bean name="client" class="net.a_cappella.presto.ft.collective.CollectiveMember" init-method="start">
        <constructor-arg index="0" ref="msgCoder" />
        <constructor-arg index="1" value="${collective.cores.list.version}" />
        <constructor-arg index="2" value="${collective.cores.list}" />
        <property name="myInfo" value="${collective.myInfo}" />
        <property name="versionedParamsCache" ref="versionedParamsCache" />
        <property name="reconnectIntervalMillis" value="${reconnect.interval.millis}"/>
    </bean>

    <!-- import resource="jmx.xml"/ -->
</beans>