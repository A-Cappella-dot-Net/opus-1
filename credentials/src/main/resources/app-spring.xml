<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <import resource="madrigalConfig.xml"/>
    <import resource="prestoClient.xml"/>

    <bean name="userDirectory" class="net.a_cappella.credentials.FileCredentialsPublisher" init-method="start">
        <property name="usersFile" value="./app/users.csv" />
        <property name="client" ref="client"/>
    </bean>

    <!-- import resource="jmx.xml"/ -->
</beans>