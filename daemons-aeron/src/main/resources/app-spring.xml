<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <import resource="allegroBeans.xml"/>

    <import resource="presto-msg-insts.xml"/>
    <import resource="presto-msg-insts-list.xml"/>
    <import resource="presto-msg-insts-pool.xml"/>

    <bean name="msgCoder" class="net.a_cappella.continuo.msg.MsgCoder" />

    <bean name="versionedParamsCache" class="net.a_cappella.presto.ft.upgrade.VersionedParamsCache" init-method="start">
        <constructor-arg index="0" value="${upgraded.params.file}" />
    </bean>

    <bean name="daemon" class="net.a_cappella.presto.ps.AeronDaemon" init-method="start">
        <property name="myInfo" value="${daemon.collective.myInfo}" />
        <property name="versionedParamsCache" ref="versionedParamsCache" />
        <property name="reconnectIntervalMillis" value="${reconnect.interval.millis}"/>
        <property name="connectionTimeoutMicros" value="${connection.timeout.micros}"/>

        <property name="conductorIdleStrategy" value="${conductor.idle.strategy}"/>
        <property name="receiverIdleStrategy" value="${receiver.idle.strategy}"/>
        <property name="senderIdleStrategy" value="${sender.idle.strategy}"/>
        <property name="threadingMode" value="${threading.mode}"/>

        <property name="pinToCpu" value="${pin.driver.to.cpu}"/>

        <constructor-arg index="0" ref="msgCoder" />
        <constructor-arg index="1" value="${collective.cores.list.version}" />
        <constructor-arg index="2" value="${collective.cores.list}" />
    </bean>

    <!-- import resource="jmx.xml"/ -->
</beans>