<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <bean id="log4jInitializer" class="org.springframework.beans.factory.config.MethodInvokingFactoryBean">
        <property name="targetClass" value="org.apache.logging.log4j.core.config.Configurator"/>
        <property name="targetMethod" value="initialize"/>
        <property name="arguments">
            <list>
                <null/>
                <value>file:./app/log4j2.xml</value>
            </list>
        </property>
    </bean>

    <bean id="processInfo" class="net.a_cappella.continuo.ProcessInfo" init-method="logProcessInfo"/>

    <bean name="settings" class="org.springframework.beans.factory.config.PropertyPlaceholderConfigurer">
        <property name="locations">
            <list>
                <value>file:./config/config.properties</value>
                <value>file:./config/config.${env}.properties</value>
                <value>file:./config/config${instance}.properties</value>
                <value>file:./config/config${instance}.upgraded.properties</value>
            </list>
        </property>
        <property name="ignoreUnresolvablePlaceholders" value="true" />
        <property name="ignoreResourceNotFound" value="true" />
    </bean>

</beans>