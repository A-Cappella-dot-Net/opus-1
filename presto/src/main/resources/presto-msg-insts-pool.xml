<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <!-- references objects defined in presto-msg-insts.xml -->

    <bean name="presto-msg-insts-pool" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <!-- Msg -->
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.bytes" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.versioned.string" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.force.disconnect" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.registration.request" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.registration.response" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.ft.member.msg" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.ft.monitor.msg" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.source.ports" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="presto.paths.subjects" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
                <bean class="net.a_cappella.continuo.managed.Pool">
                    <constructor-arg name="instantiator" ref="allegro.test.msg" />
                    <constructor-arg name="initialSize" value="10" />
                    <constructor-arg name="incrementSize" value="10" />
                </bean>
            </list>
        </constructor-arg>
    </bean>

    <bean class="net.a_cappella.continuo.managed.ObjectInitializer">
        <property name="msgPools" ref="presto-msg-insts-pool"/>
    </bean>

</beans>