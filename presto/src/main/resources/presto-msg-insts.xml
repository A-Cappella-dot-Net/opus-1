<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <bean name="presto.bytes" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.continuo.msg.Bytes" />
        <constructor-arg name="argClassNames">
            <list>
                <value>java.lang.Integer</value>
            </list>
        </constructor-arg>
        <constructor-arg name="args">
            <list>
                <value>1024</value>
            </list>
        </constructor-arg>
    </bean>
    <bean name="presto.versioned.string" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.presto.msg.VersionedStringMsg" />
    </bean>
    <bean name="presto.force.disconnect" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.continuo.msg.ForceDisconnect" />
    </bean>
    <bean name="presto.registration.request" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.continuo.msg.RegistrationRequest" />
    </bean>
    <bean name="presto.registration.response" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.continuo.msg.RegistrationResponse" />
    </bean>
    <bean name="presto.ft.member.msg" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.presto.msg.FtMemberMsg" />
    </bean>
    <bean name="presto.ft.monitor.msg" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.presto.msg.FtMonitorMsg" />
    </bean>
    <bean name="presto.source.ports" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.presto.msg.SourcesMsg" />
    </bean>
    <bean name="presto.paths.subjects" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.presto.msg.PathsSubjectsMsg" />
    </bean>
    <bean name="allegro.test.msg" class="net.a_cappella.continuo.managed.MsgInstantiator">
        <constructor-arg name="className" value="net.a_cappella.continuo.msg.TestMsg" />
    </bean>

</beans>