<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <bean name="msgCoder" class="net.a_cappella.continuo.msg.MsgCoder" />

    <bean name="tightLoopThread" class="net.a_cappella.continuo.utils.tightloop.TightLoopThread" init-method="start">
        <property name="microThreshold" value="${client.micro.threshold}" />
        <property name="idleStrategy" value="${client.idle.strategy}"/>
        <property name="pinToCpu" value="${pin.tlt.to.cpu}"/>
    </bean>

    <bean name="pubHelper" class="net.a_cappella.presto.ps.PublicationHelper">
        <property name="retriesOnBackPressure" value="${retries.on.back.pressure}"/>
        <property name="sleepNanosOnBackPressureRetry" value="${sleep.nanos.on.back.pressure.retry}"/>
    </bean>

    <bean name="client" class="net.a_cappella.presto.ps.AeronClient" init-method="start" scope="singleton">
        <constructor-arg index="0" ref="msgCoder" />
        <constructor-arg index="1" value="${connection.info}" />
        <constructor-arg index="2" value="${mon.conf.interval}" />
        <constructor-arg index="3" value="${mem.conf.interval}" />
        <constructor-arg index="4" ref="tightLoopThread" />
        <constructor-arg index="5" ref="pubHelper" />
        <constructor-arg index="6">
            <map>
                <entry key="fromInit" value="${snap.timeout.from.init}"/>
                <entry key="fromLatest" value="${snap.timeout.from.latest}"/>
            </map>
        </constructor-arg>

        <property name="useIpcLoopback" value="${use.ipc.loopback}"/>
        <property name="multicastChannel" value="${multicast.channel}"/>
        <property name="unicastChannel" value="${unicast.channel}"/>
        <property name="channelType" value="${channel.type}"/>
        <property name="pubStream" value="${pub.stream}"/>
        <property name="subStream" value="${sub.stream}"/>
        <property name="reconnectIntervalMillis" value="${reconnect.interval.millis}"/>
        <property name="connectionTimeoutMillis" value="${connection.timeout.millis}"/>
    </bean>

</beans>
