<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <bean name="ecn0Credentials" class="net.a_cappella.cembalo.Credentials">
        <constructor-arg index="0">
        	<map>
        		<entry key="internal">
		        	<map>
	    	    		<entry key="sim0" value="sim0"/>
	        		</map>
        		</entry>
        		<entry key="cl0">
		        	<map>
		        		<entry key="mm0" value="mm0Pwd"/>
	        		</map>
        		</entry>
        		<entry key="cl1">
		        	<map>
		        		<entry key="mm0" value="mm0Pwd"/>
	        		</map>
        		</entry>
        		<entry key="cl2">
		        	<map>
		        		<entry key="mm0" value="mm0Pwd"/>
		        		<entry key="ex0" value="ex0Pwd"/>
	        		</map>
        		</entry>
        	</map>
        </constructor-arg>
    </bean>

    <bean name="ecn1Credentials" class="net.a_cappella.cembalo.Credentials">
        <constructor-arg index="0">
        	<map>
        		<entry key="cl0">
		        	<map>
		        		<entry key="mm1" value="mm1Pwd"/>
	        		</map>
        		</entry>
        		<entry key="cl1">
		        	<map>
		        		<entry key="mm1" value="mm1Pwd"/>
	        		</map>
        		</entry>
        		<entry key="cl2">
		        	<map>
		        		<entry key="mm1" value="mm1Pwd"/>
	        		</map>
        		</entry>
        	</map>
        </constructor-arg>
    </bean>

    <bean name="ecn2Credentials" class="net.a_cappella.cembalo.Credentials">
        <constructor-arg index="0">
        	<map>
        		<entry key="cl0">
		        	<map>
		        		<entry key="mm2" value="mm2Pwd"/>
	        		</map>
        		</entry>
        		<entry key="cl1">
		        	<map>
		        		<entry key="mm2" value="mm2Pwd"/>
	        		</map>
        		</entry>
        		<entry key="cl2">
		        	<map>
		        		<entry key="mm2" value="mm2Pwd"/>
	        		</map>
        		</entry>
        	</map>
        </constructor-arg>
    </bean>

</beans>